<Window x:Class="WingMultitrackRenamer.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Wing Multitrack Renamer"
        Width="760"
        Height="760"
        MinWidth="760"
        MinHeight="760"
        ResizeMode="CanMinimize"
        Background="#111111"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#151515" />
        <SolidColorBrush x:Key="PanelBrush" Color="#0E0E0E" />
        <SolidColorBrush x:Key="OutlineBrush" Color="#CFC7B9" />
        <SolidColorBrush x:Key="MutedBrush" Color="#998F80" />
        <SolidColorBrush x:Key="TextBrush" Color="#F2EEE8" />
        <SolidColorBrush x:Key="AmberBrush" Color="#F4AD20" />
        <SolidColorBrush x:Key="AmberInkBrush" Color="#5E3A00" />
        <SolidColorBrush x:Key="CyanBrush" Color="#5CE5FF" />
        <SolidColorBrush x:Key="DangerBrush" Color="#FFB4AA" />

        <Style x:Key="SegmentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DropPanelBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        </Style>
    </Window.Resources>

    <Border Margin="20" Padding="20" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Wing Multitrack Renamer"
                       Foreground="{StaticResource TextBrush}"
                       FontFamily="Consolas"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,14" />

            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="FolderPanel"
                        Grid.Column="0"
                        Style="{StaticResource DropPanelBorderStyle}"
                        Padding="14"
                        AllowDrop="True"
                        MouseLeftButtonUp="FolderPanel_MouseLeftButtonUp"
                        DragOver="Panel_DragOver"
                        Drop="FolderPanel_Drop">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SLOT 1: SOURCE" Foreground="{StaticResource CyanBrush}" FontFamily="Consolas" FontSize="11" FontWeight="Bold" />
                        <TextBlock Text="{Binding FolderPrimaryText}" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontSize="18" FontWeight="Bold" TextAlignment="Center" Margin="0,24,0,8" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding FolderSecondaryText}" Foreground="{StaticResource MutedBrush}" FontFamily="Consolas" FontSize="12" TextAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border x:Name="SnapPanel"
                        Grid.Column="2"
                        Style="{StaticResource DropPanelBorderStyle}"
                        Padding="14"
                        AllowDrop="True"
                        MouseLeftButtonUp="SnapPanel_MouseLeftButtonUp"
                        DragOver="Panel_DragOver"
                        Drop="SnapPanel_Drop">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SLOT 2: REFERENCE" Foreground="{StaticResource CyanBrush}" FontFamily="Consolas" FontSize="11" FontWeight="Bold" />
                        <TextBlock Text="{Binding SnapPrimaryText}" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontSize="18" FontWeight="Bold" TextAlignment="Center" Margin="0,24,0,8" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding SnapSecondaryText}" Foreground="{StaticResource MutedBrush}" FontFamily="Consolas" FontSize="12" TextAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1" HorizontalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Command="{Binding SelectCardACommand}" BorderThickness="0,0,1,0" BorderBrush="{StaticResource OutlineBrush}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SegmentButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCardA}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AmberBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource AmberInkBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel>
                                <TextBlock Text="CARD A" HorizontalAlignment="Center" />
                                <TextBlock Text="1-32" FontSize="10" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="1" Command="{Binding SelectCardBCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SegmentButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCardB}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AmberBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource AmberInkBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel>
                                <TextBlock Text="CARD B" HorizontalAlignment="Center" />
                                <TextBlock Text="33-64" FontSize="10" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Column="2" BorderBrush="{StaticResource OutlineBrush}" BorderThickness="1" HorizontalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Command="{Binding SelectRenameCommand}" BorderThickness="0,0,1,0" BorderBrush="{StaticResource OutlineBrush}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SegmentButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRenameMode}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AmberBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource AmberInkBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="RENAME" />
                        </Button>

                        <Button Grid.Column="1" Command="{Binding SelectCopyCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SegmentButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCopyMode}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AmberBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource AmberInkBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="COPY" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <Button Grid.Row="3"
                    Command="{Binding ExecuteCommand}"
                    Content="{Binding ExecuteButtonText}"
                    FontFamily="Consolas"
                    FontWeight="Bold"
                    FontSize="18"
                    Background="{StaticResource AmberBrush}"
                    Foreground="{StaticResource AmberInkBrush}"
                    BorderBrush="{StaticResource OutlineBrush}"
                    BorderThickness="1"
                    Height="50"
                    Margin="0,0,0,16" />

            <Border Grid.Row="4" BorderBrush="#40CFC7B9" BorderThickness="0,1,0,1" Padding="0,14" Margin="0,0,0,16">
                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <TextBlock Text="SYSTEM STATUS" Foreground="{StaticResource CyanBrush}" FontFamily="Consolas" FontWeight="Bold" DockPanel.Dock="Left" />
                        <TextBlock Text="{Binding StatusFlag}" Foreground="{StaticResource AmberBrush}" FontFamily="Consolas" FontWeight="Bold" DockPanel.Dock="Right" />
                    </DockPanel>
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" Margin="0,10,0,10" TextWrapping="Wrap" />
                    <ProgressBar Minimum="0" Maximum="{Binding ProgressMaximum}" Value="{Binding ProgressValue}" Height="12" Margin="0,0,0,10" />
                    <WrapPanel Margin="0,0,0,8">
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="ROWS" Foreground="{StaticResource MutedBrush}" FontFamily="Consolas" FontSize="11" />
                            <TextBlock Text="{Binding RowsMetric}" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="CARD" Foreground="{StaticResource MutedBrush}" FontFamily="Consolas" FontSize="11" />
                            <TextBlock Text="{Binding CardMetric}" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="MODE" Foreground="{StaticResource MutedBrush}" FontFamily="Consolas" FontSize="11" />
                            <TextBlock Text="{Binding ModeMetric}" Foreground="{StaticResource TextBrush}" FontFamily="Consolas" FontWeight="Bold" />
                        </StackPanel>
                    </WrapPanel>
                    <TextBlock Text="{Binding OutputPath}" Foreground="{StaticResource MutedBrush}" FontFamily="Consolas" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <DataGrid Grid.Row="5"
                      ItemsSource="{Binding Rows}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      RowHeaderWidth="0"
                      Background="Transparent"
                      BorderThickness="0"
                      HorizontalGridLinesBrush="#26CFC7B9"
                      VerticalGridLinesBrush="Transparent"
                      Foreground="{StaticResource TextBrush}"
                      FontFamily="Consolas"
                      FontSize="12"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Setter Property="BorderBrush" Value="#26CFC7B9" />
                        <Setter Property="FontFamily" Value="Consolas" />
                        <Setter Property="FontSize" Value="11" />
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="Padding" Value="8" />
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="8" />
                    </Style>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Original" Binding="{Binding OriginalName}" Width="2*" />
                    <DataGridTextColumn Header="Abs" Binding="{Binding AbsoluteSlot}" Width="80" />
                    <DataGridTextColumn Header="Final" Binding="{Binding FinalName}" Width="3*" />
                    <DataGridTextColumn Header="State" Binding="{Binding Status}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</Window>
