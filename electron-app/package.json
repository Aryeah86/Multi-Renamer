{
  "name": "wing-multitrack-renamer-electron",
  "version": "1.0.0",
  "private": true,
  "description": "Cross-platform Wing multitrack renamer desktop app",
  "author": "Lev Aranovich",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist:dir": "electron-builder --dir",
    "dist:mac": "electron-builder --mac dmg zip",
    "dist:win": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.aryeah86.wingmultitrackrenamer",
    "productName": "Wing Multitrack Renamer",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.music",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "sign": true,
      "contents": [
        {
          "x": 180,
          "y": 190,
          "type": "file"
        },
        {
          "x": 500,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 780,
        "height": 520
      }
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^38.3.0",
    "electron-builder": "^26.0.12"
  }
}
